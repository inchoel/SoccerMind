# SoccerMind 환경 변수 — 본인 키를 채우고 .env 로 복사하세요. .env 는 절대 커밋하지 마세요.

# 선택 (무료 자가발급): https://www.football-data.org/client/register  — 스쿼드 백본
# 주의: 무료 티어는 per-player 득점 통계가 빈약(goals=0). 득점자 품질은 Wikipedia 폴백이 더 나을 수 있음.
# 또한 검증된 fd_id 매핑이 있어야 실제 호출됨(없으면 자동 스킵 → 출처에 미표시).
FOOTBALL_DATA_TOKEN=

# 선택 (무료 100/일): https://dashboard.api-football.com/register  — WC 심층 데이터
API_FOOTBALL_KEY=

# 선택: 없으면 통계 예측 + 템플릿 해설로 동작 (graceful degradation)
ANTHROPIC_API_KEY=

# 기본 테스트키(키 불필요). 개인키는 Patreon 필요.
THESPORTSDB_KEY=123

# eloratings.net / Wikipedia 는 키가 필요 없습니다.

# 부상/결장 속보 웹검색 옵트인 (기본 비활성). 1 로 설정하면 예측 시 DuckDuckGo 검색.
ENABLE_WEB_SEARCH=
