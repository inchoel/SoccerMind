# SoccerMind 환경 변수 — 본인 키를 채우고 .env 로 복사하세요. .env 는 절대 커밋하지 마세요.

# 필수 권장 (무료 자가발급): https://www.football-data.org/client/register  — 백본 데이터
FOOTBALL_DATA_TOKEN=

# 선택 (무료 100/일): https://dashboard.api-football.com/register  — WC 심층 데이터
API_FOOTBALL_KEY=

# 선택: 없으면 통계 예측 + 템플릿 해설로 동작 (graceful degradation)
ANTHROPIC_API_KEY=

# 기본 테스트키(키 불필요). 개인키는 Patreon 필요.
THESPORTSDB_KEY=123

# eloratings.net / Wikipedia 는 키가 필요 없습니다.
